spring.application.name=logistica-auth
server.port=8095

eureka.client.service-url.defaultZone=http://localhost:8761/eureka
eureka.instance.instance-id=${spring.application.name}:${random.value}

# PostgreSQL 16
spring.datasource.url=jdbc:postgresql://localhost:5432/db_logistica
spring.datasource.username=postgres
spring.datasource.password=123456
spring.datasource.driver-class-name=org.postgresql.Driver

# Quitar el dialecto explícito — PostgreSQL 16 lo detecta automáticamente
# spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect  ← ELIMINAR ESTA LÍNEA

spring.jpa.generate-ddl=true
spring.jpa.hibernate.ddl-auto=update
spring.jpa.properties.hibernate.jdbc.lob.non_contextual_creation=true

